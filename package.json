{
  "name": "shepherd-architecture",
  "version": "1.0.0-alpha",
  "description": "牧羊人架构框架 - 人机协同软件开发架构",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "benchmark": "node scripts/benchmark.js",
    "experiment:tetris": "node scripts/experiment.js",
    "experiment:computer": "node scripts/computer_design.js",
    "experiment:api": "node scripts/real_api_comparison.js",
    "experiment:video": "node scripts/video_engine_batch.js",
    "experiment:ecommerce": "node scripts/ecommerce_experiment.js",
    "stats": "node scripts/project_stats.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/"
  },
  "keywords": [
    "ai",
    "agent",
    "human-ai-collaboration",
    "software-engineering",
    "framework",
    "shepherd",
    "architecture",
    "multi-agent"
  ],
  "author": "牧羊人架构研究团队",
  "license": "MIT",
