NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/shepherd
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=debug

# Shepherd Configuration
MAX_AGENTS=50
GOVERNANCE_MATURITY=0.5

# Features
ENABLE_AUDIT_CHAIN=true
SANDBOX_ENABLED=true
CODE_REVIEW_REQUIRED=true

# LLM Provider (mock | anthropic | openai)
LLM_PROVIDER=mock
LLM_MODEL=claude-3-sonnet
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=

# OpenAI API Key (optional)
OPENAI_API_KEY=
